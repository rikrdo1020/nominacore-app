{
  "name": "nominacore",
  "version": "1.0.8",
  "description": "Control de horas y pagos de empleados",
  "author": "NominaCore",
  "main": "electron-dist/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/rikrdo1020/nominacore-app.git"
  },
  "scripts": {
    "dev": "vite build && npm run build:electron && electron .",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "electron .",
    "pack": "vite build && npm run build:electron && electron-builder --dir",
    "release": "node scripts/release.js",
    "vite:dev": "vite",
    "electron:dev": "vite build && npm run build:electron && electron .",
    "dev:win": "vite build && npm run build:electron && electron-builder --dir --win nsis && start release/win-unpacked/NominaCore.exe"
  },
  "build": {
    "appId": "com.valentini.assistant",
    "productName": "NominaCore",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "NominaCore"
    },
    "publish": {
      "provider": "github",
      "owner": "rikrdo1020",
      "repo": "nominacore-app",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.76.1",
    "react-router-dom": "^6.26.0",
    "sql.js": "^1.11.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "29.4.6",
    "electron-builder": "^26.8.1",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "to-ico-cli": "^1.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.2"
  }
}
